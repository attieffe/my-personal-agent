io":1.625,"no_speech_prob":0.1535916030406952},{"id":50,"seek":23000,"start":240.0,"end":244.0,"text":" Non è che puoi tagliare corto e fare 100 o 250.","tokens":[50864,8774,4873,947,2362,4869,6162,2081,543,11278,78,308,11994,2319,277,11650,13,51064],"temperature":0.0,"avg_logprob":-0.31518957018852234,"compression_ratio":1.625,"no_speech_prob":0.1535916030406952},{"id":51,"seek":23000,"start":245.0,"end":249.0,"text":" Credo che tanto questo è l'unico tipo di ragionamento che puoi fare.","tokens":[51114,47560,78,947,10331,10263,4873,287,6,409,2789,9746,1026,17539,313,8824,947,2362,4869,11994,13,51314],"temperature":0.0,"avg_logprob":-0.31518957018852234,"compression_ratio":1.625,"no_speech_prob":0.1535916030406952},{"id":52,"seek":23000,"start":249.0,"end":251.0,"text":" Poi, hai capito qual è?","tokens":[51314,430,4869,11,21822,1410,3528,4101,4873,30,51414],"temperature":0.0,"avg_logprob":-0.31518957018852234,"compression_ratio":1.625,"no_speech_prob":0.1535916030406952},{"id":53,"seek":23000,"start":251.0,"end":255.0,"text":" Cioè, poi ti la guerra l'attrezzo e capire, ma l'anno scorso ti hai fatto sto sconto così,","tokens":[51414,383,35983,11,19260,8757,635,27542,287,6,1591,265,35130,308,1410,621,11,463,287,6,13484,38629,539,8757,21822,23228,22784,795,7556,23278,11,51614],"temperature":0.0,"avg_logprob":-0.31518957018852234,"compression_ratio":1.625,"no_speech_prob":0.1535916030406952},{"id":54,"seek":23000,"start":255.0,"end":256.0,"text":" così, qua non li vedo questi sconti.","tokens":[51614,23278,11,24159,2107,375,14267,78,29729,795,896,72,13,51664],"temperature":0.0,"avg_logprob":-0.31518957018852234,"compression_ratio":1.625,"no_speech_prob":0.1535916030406952},{"id":55,"seek":23000,"start":256.0,"end":257.0,"text":" Com'è questa storia?","tokens":[51664,2432,6,1462,16540,5967,654,30,51714],"temperature":0.0,"avg_logprob":-0.31518957018852234,"compression_ratio":1.625,"no_speech_prob":0.1535916030406952},{"id":56,"seek":25700,"start":258.0,"end":262.0,"text":" E poi si vedeva da Stefano che si incazzerà e chiamerà non so chi,","tokens":[50414,462,19260,1511,371,4858,2757,1120,43421,3730,947,1511,294,496,4313,260,1467,308,417,2918,260,1467,2107,370,13228,11,50614],"temperature":0.0,"avg_logprob":-0.2971916198730469,"compression_ratio":1.4695652723312378,"no_speech_prob":0.2934834361076355},{"id":57,"seek":25700,"start":262.0,"end":266.0,"text":" e poi confermeremo, per forza.","tokens":[50614,308,19260,13765,76,323,3280,11,680,337,2394,13,50814],"temperature":0.0,"avg_logprob":-0.2971916198730469,"compression_ratio":1.4695652723312378,"no_speech_prob":0.2934834361076355},{"id":58,"seek":25700,"start":271.0,"end":273.0,"text":" Non c'è molto altro di cui parlare, credo, no?","tokens":[51064,8774,269,6,1462,16394,40924,1026,22929,13734,543,11,3864,78,11,572,30,51164],"temperature":0.0,"avg_logprob":-0.2971916198730469,"compression_ratio":1.4695652723312378,"no_speech_prob":0.2934834361076355},{"id":59,"seek":25700,"start":274.0,"end":275.0,"text":" Oh no, sì, sì.","tokens":[51214,876,572,11,49267,11,49267,13,51264],"temperature":0.0,"avg_logprob":-0.2971916198730469,"compression_ratio":1.4695652723312378,"no_speech_prob":0.2934834361076355},{"id":60,"seek":25700,"start":275.0,"end":277.0,"text":" Tanto quelle robe ci servono, cioè...","tokens":[51264,314,5857,29237,37213,6983,1658,8957,11,41827,485,51364],"temperature":0.0,"avg_logprob":-0.2971916198730469,"compression_ratio":1.4695652723312378,"no_speech_prob":0.2934834361076355},{"id":61,"seek":25700,"start":278.0,"end":283.0,"text":" Non ho capito poi se Bartolini lo teniamo o no, perché Giorgio non ho capito cosa ha detto.","tokens":[51414,8774,1106,1410,3528,19260,369,22338,401,3812,450,2064,7415,277,572,11,14303,460,1973,17862,2107,1106,1410,3528,10163,324,41031,13,51664],"temperature":0.0,"avg_logprob":-0.2971916198730469,"compression_ratio":1.4695652723312378,"no_speech_prob":0.2934834361076355},{"id":62,"seek":25700,"start":283.0,"end":284.0,"text":" Magari lo stevi in chat.","tokens":[51664,6395,3504,450,2126,4917,294,5081,13,51714],"temperature":0.0,"avg_logprob":-0.2971916198730469,"compression_ratio":1.4695652723312378,"no_speech_prob":0.2934834361076355},{"id":63,"seek":25700,"start":284.0,"end":285.0,"text":" Sì, lo teniamo.","tokens":[51714,318,4749,11,450,2064,7415,13,51764],"temperature":0.0,"avg_logprob":-0.2971916198730469,"compression_ratio":1.4695652723312378,"no_speech_prob":0.2934834361076355},{"id":64,"seek":28500,"start":285.0,"end":286.0,"text":" Ma fai...","tokens":[50364,4042,283,1301,485,50414],"temperature":0.0,"avg_logprob":-0.24631009995937347,"compression_ratio":1.0449438095092773,"no_speech_prob":0.05026503652334213},{"id":65,"seek":28500,"start":286.0,"end":287.0,"text":" Sì.","tokens":[50414,318,4749,13,50464],"temperature":0.0,"avg_logprob":-0.24631009995937347,"compression_ratio":1.0449438095092773,"no_speech_prob":0.05026503652334213},{"id":66,"seek":28500,"start":287.0,"end":288.0,"text":" Ok.","tokens":[50464,3477,13,50514],"temperature":0.0,"avg_logprob":-0.24631009995937347,"compression_ratio":1.0449438095092773,"no_speech_prob":0.05026503652334213},{"id":67,"seek":28500,"start":290.0,"end":292.0,"text":" Facciamogli delle domande sì o no.","tokens":[50614,17667,537,335,664,2081,16485,3285,11123,49267,277,572,13,50714],"temperature":0.0,"avg_logprob":-0.24631009995937347,"compression_ratio":1.0449438095092773,"no_speech_prob":0.05026503652334213},{"id":68,"seek":28500,"start":293.0,"end":294.0,"text":" Sì o no.","tokens":[50764,318,4749,277,572,13,50814],"temperature":0.0,"avg_logprob":-0.24631009995937347,"compression_ratio":1.0449438095092773,"no_speech_prob":0.05026503652334213},{"id":69,"seek":28500,"start":295.0,"end":296.0,"text":" Era incazzato il Gigi.","tokens":[50864,23071,294,496,4313,2513,1930,460,19789,13,50914],"temperature":0.0,"avg_logprob":-0.24631009995937347,"compression_ratio":1.0449438095092773,"no_speech_prob":0.05026503652334213},{"id":70,"seek":28500,"start":299.